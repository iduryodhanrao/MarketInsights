# ─────────────────────────────────────────────
# Market Insights — Environment Configuration
# Copy this file to .env and fill in your keys
# ─────────────────────────────────────────────

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# RapidAPI (single key works for all subscribed APIs)
RAPIDAPI_KEY=your_rapidapi_key_here
YAHOO_FINANCE_HOST=yahoo-finance15.p.rapidapi.com
NEWS_API_HOST=real-time-news-data.p.rapidapi.com

# LangSmith Tracing (optional but recommended)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=MarketInsights
